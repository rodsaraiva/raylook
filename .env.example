# ============================================
# raylook (sandbox local) — Environment Variables
# ============================================
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o arquivo .env com dados reais
# ============================================

# --------------------------------------------
# Application Settings
# --------------------------------------------
# Sandbox global. true = nada bate em API real (Asaas/Resend/etc.).
# Default true. Mude pra false só se você sabe o que está fazendo.
RAYLOOK_SANDBOX=true

# Backend de persistência. "sqlite" (default) usa data/raylook.db;
# "supabase" só funciona com RAYLOOK_SANDBOX=false. Em sandbox
# qualquer valor é coagido pra "sqlite".
DATA_BACKEND=sqlite

TZ=America/Sao_Paulo
DATA_DIR=/app/data
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
WELCOME_NAME=raylook
ALLOWED_ORIGINS=["*"]
COMMISSION_PERCENT=13
PACKAGE_LIMIT_TOTAL=24

# --------------------------------------------
# Test Mode
# --------------------------------------------
TEST_MODE=false
TEST_PHONE_NUMBER=
ESTOQUE_PHONE_NUMBER=

# --------------------------------------------
# OpenAI
# --------------------------------------------
OPENAI_API_KEY=sk-...

# --------------------------------------------
# WhatsApp Groups (authorized)
# --------------------------------------------
AUTHORIZED_GROUP_1=
AUTHORIZED_GROUP_2=

# --------------------------------------------
# Manager WhatsApp Numbers
# --------------------------------------------
MANAGER_PHONE_1=
MANAGER_PHONE_2=

# --------------------------------------------
# WhatsApp Cloud API (Meta)
# --------------------------------------------
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=

# --------------------------------------------
# Asaas Integration
# ASAAS_PROD_TOKEN é obrigatório em produção (RAYLOOK_SANDBOX=false)
# --------------------------------------------
ASAAS_PROD_TOKEN=
ASAAS_POLL_RETRIES=12
ASAAS_POLL_INITIAL_DELAY=
ASAAS_POLL_MAX_DELAY=

# Habilita endpoints de criação de pacote do zero (adhoc). Default: false.
ADHOC_PACKAGES_ENABLED=false
