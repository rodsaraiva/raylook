# Raylook prod env — copie pra /root/projects/raylook-deploy/.env (FORA do repo)
# e preencha. NUNCA commite o .env real.
#
# Gere secrets fortes:
#   POSTGRES_PASSWORD       openssl rand -hex 24
#   PGRST_JWT_SECRET        openssl rand -hex 32
#   DASHBOARD_AUTH_PASS     openssl rand -base64 16
#   WHATSAPP_WEBHOOK_SECRET openssl rand -hex 32

# --- Postgres dedicado ---
POSTGRES_PASSWORD=

# --- PostgREST (autenticação pro app falar com o postgrest) ---
PGRST_JWT_SECRET=

# --- Dashboard auth ---
DASHBOARD_AUTH_USER=admin
DASHBOARD_AUTH_PASS=

# --- WHAPI (canal próprio do raylook) ---
WHAPI_TOKEN=
WHAPI_API_URL=https://gate.whapi.cloud
OFFICIAL_GROUP_CHAT_ID=
AUTHORIZED_GROUP_1=
AUTHORIZED_GROUP_2=

# --- Webhook secret (configurar mesmo valor na WHAPI cloud) ---
WHATSAPP_WEBHOOK_SECRET=

# --- Sandbox flag ---
# true  → integrações Asaas/Resend continuam stub (recomendado até cada
#         uma estar configurada com credenciais próprias do raylook).
# false → integrações reais ativas.
RAYLOOK_SANDBOX=true

# --- Image override (CI seta automaticamente; default usa :latest) ---
DOCKER_IMAGE=ghcr.io/rodsaraiva/raylook:latest
